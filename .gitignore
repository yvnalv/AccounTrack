# ==============================================================================
# Accountrack .gitignore
# Stack: .NET 8 (backend) · Vue 3 + TypeScript/Vite (frontend) · Docker · SQL Server
# Sources: github/gitignore Dotnet + VisualStudio + Node, tailored to this repo layout.
# ==============================================================================

# ------------------------------------------------------------------------------
# Secrets & local configuration  (NEVER commit — see docs/SECURITY.md §6)
# ------------------------------------------------------------------------------
*.env
.env
.env.*
!.env.example
appsettings.*.local.json
appsettings.Local.json
secrets.json
*.secrets.json
*.pfx
*.p12
*.key
*.pem
# ASP.NET Core user-secrets are stored outside the repo by design; keep any stray copies out:
**/UserSecrets/

# ------------------------------------------------------------------------------
# .NET / C# build output
# ------------------------------------------------------------------------------
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
artifacts/
project.lock.json
project.fragment.lock.json
*.binlog

# Build / publish
publish/
[Pp]ublish/
*.publishproj
PublishScripts/

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
.nuget/

# ASP.NET scaffolding
ScaffoldingReadMe.txt

# ------------------------------------------------------------------------------
# .NET test / coverage results
# ------------------------------------------------------------------------------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
CodeCoverage/
coverage/
*.coverage
*.coveragexml
TestResults/
[Cc]overage*.json
[Cc]overage*.xml
[Cc]overage*.info

# ------------------------------------------------------------------------------
# Visual Studio / Rider / VS Code
# ------------------------------------------------------------------------------
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
*_i.c
*_p.c
*.rsp

# JetBrains Rider
.idea/
*.sln.iml

# VS Code — keep shared settings, ignore personal/local
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# ------------------------------------------------------------------------------
# Node / Vue 3 / Vite (frontend/)
# ------------------------------------------------------------------------------
node_modules/
.pnpm-store/
.npm/
.yarn/
.yarn-cache/
jspm_packages/

# Vite / build output
frontend/dist/
frontend/dist-ssr/
dist/
dist-ssr/
*.local

# Framework / tooling caches
.vite/
.cache/
.temp/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Vitest / coverage / Playwright
coverage/
.nyc_output/
playwright-report/
test-results/
/playwright/.cache/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
# Ignore local compose overrides; keep the committed compose files.
docker-compose.override.yml
docker-compose.*.local.yml
*.env.docker

# ------------------------------------------------------------------------------
# SQL Server / database local artifacts
# ------------------------------------------------------------------------------
*.mdf
*.ldf
*.ndf
*.bak
*.bacpac
*.dacpac.local

# ------------------------------------------------------------------------------
# OS files
# ------------------------------------------------------------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
# Linux
*~
.directory
.Trash-*

# ------------------------------------------------------------------------------
# Misc / temp
# ------------------------------------------------------------------------------
~$*
*.tmp
*.temp
*.swp
*.swo
*.bak
*.orig
*.rej
