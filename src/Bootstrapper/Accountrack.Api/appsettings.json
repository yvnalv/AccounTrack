{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Auth": {
      "PermitLimit": 20,
      "WindowSeconds": 60
    }
  },
  "Billing": {
    "Entitlements": {
      "Enforce": false
    },
    "Xendit": {
      "BaseUrl": "https://api.xendit.co",
      "SuccessRedirectUrl": "",
      "FailureRedirectUrl": ""
    }
  }
}
