<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Identity.Api: HTTP endpoints for the Identity module (auth). Thin layer that dispatches
    commands/queries via MediatR and maps Result -> HTTP via Web.Common (ARCHITECTURE.md §8).
  -->
  <PropertyGroup>
    <RootNamespace>Accountrack.Identity.Api</RootNamespace>
    <AssemblyName>Accountrack.Identity.Api</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MediatR" Version="12.4.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Accountrack.Identity.Application\Accountrack.Identity.Application.csproj" />
    <ProjectReference Include="..\..\..\BuildingBlocks\Accountrack.Web.Common\Accountrack.Web.Common.csproj" />
  </ItemGroup>

</Project>
