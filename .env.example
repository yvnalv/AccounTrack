# Accountrack deployment config. Copy to `.env` and fill in. NEVER commit the real .env (gitignored).

# --- PostgreSQL (containerised) ---
# Database name, application user, and a strong password for that user.
POSTGRES_DB=Accountrack
POSTGRES_USER=accountrack
POSTGRES_PASSWORD=Change_this_Str0ng_Passw0rd!

# --- Auth (REQUIRED) ---
# A strong random secret, >= 32 chars. Generate e.g.:  openssl rand -base64 48
JWT_SIGNING_KEY=replace-with-a-long-random-secret-min-32-chars
JWT_ISSUER=Accountrack
JWT_AUDIENCE=Accountrack

# --- First administrator (seeded on first boot) ---
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=Change_this_Admin_Passw0rd!
# Set to false only after your organisation + admin already exist (avoids re-seeding).
SEED_ENABLED=true

# --- Web entry point (your external reverse proxy forwards a subdomain here) ---
# Host port the SPA/Nginx container listens on. Point e.g. accountrack.yourdomain.com → host:WEB_PORT.
WEB_PORT=8090
# Bind to 127.0.0.1 if your reverse proxy runs on the same host and you don't want the port public.
WEB_BIND=0.0.0.0
